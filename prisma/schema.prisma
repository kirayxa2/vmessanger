generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int                       @id @default(autoincrement())
  email            String                    @unique
  username         String                    @unique
  password         String
  avatar           String?
  bio              String?
  lastSeen         DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  conversations    ConversationParticipant[]
  receivedMessages Message[]                 @relation("ReceivedMessages")
  sentMessages     Message[]                 @relation("SentMessages")
  drafts           Draft[]
  callsInitiated   Call[]                    @relation("CallInitiator")
  callsReceived    Call[]                    @relation("CallReceiver")
  messageReads     MessageRead[]
  reactions        Reaction[]
  pushSubscriptions PushSubscription[]
  sessions          UserSession[]
  stories           Story[]
  storyViews        StoryView[]
  publicKey         String?   // E2E: X25519/P-256 public key (base64, spki format)
  isBot             Boolean   @default(false) // системный аккаунт бота
  ownedBots         Bot[]     @relation("BotOwner")
  botProfile        Bot?      @relation("BotIdentity")
  botSessions       BotSession[]
  botFatherSession  BotFatherSession?

  @@index([lastSeen])
  @@index([isBot])
}

model Conversation {
  id              Int                       @id @default(autoincrement())
  isGroup         Boolean                   @default(false)
  name            String?
  avatar          String?
  description     String?
  type            String                    @default("private")
  maxMembers      Int                       @default(200000)
  pinnedMessageId Int?
  pinnedMessageIds Int[]                    @default([])
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  participants    ConversationParticipant[]
  messages        Message[]
  drafts          Draft[]
  calls           Call[]
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  userId         Int
  conversationId Int
  role           String       @default("member") // "owner" | "admin" | "member"
  joinedAt       DateTime     @default(now())
  isArchived     Boolean      @default(false)
  isMuted        Boolean      @default(false)
  mutedUntil     DateTime?
  folder         String?      // "archive" | null
  clearedAt      DateTime?
  deletedAt      DateTime?    // soft delete — чат скрыт только у этого юзера
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id              Int           @id @default(autoincrement())
  content         String        @default("")
  contentForSender String?      // E2E: вторая зашифрованная копия для отправителя (чтобы он мог расшифровать своё же сообщение)
  createdAt       DateTime      @default(now())
  isRead          Boolean       @default(false)
  senderId        Int
  receiverId      Int?
  conversationId  Int
  replyToId       Int?
  forwardFromId   Int?
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  fileType        String?
  voiceUrl        String?
  voiceDuration   Int?
  selfDestructAt  DateTime?
  isEncrypted     Boolean   @default(false)
  replyMarkup     Json?     // inline_keyboard, keyboard и т.д.
  botId           Int?      // если сообщение от бота
  linkPreview     Json?     // OG-превью ссылки: { url, title, description, image, siteName }
  scheduledAt     DateTime? // отложенная отправка: пока > now — сообщение скрыто, доставляется по времени

  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  receiver       User?         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender         User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo        Message?      @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]     @relation("MessageReplies")
  readBy         MessageRead[]
  reactions      Reaction[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([conversationId])
  @@index([scheduledAt])
}

model MessageRead {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Reaction {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Call {
  id             Int          @id @default(autoincrement())
  conversationId Int
  initiatorId    Int
  receiverId     Int
  type           String       // 'audio' | 'video'
  status         String       // 'calling' | 'accepted' | 'declined' | 'ended' | 'missed'
  startedAt      DateTime     @default(now())
  endedAt        DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  initiator      User         @relation("CallInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  receiver       User         @relation("CallReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Draft {
  id             Int          @id @default(autoincrement())
  text           String
  replyToId      Int?
  entities       Json?
  timestamp      DateTime     @default(now()) @updatedAt
  userId         Int
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Story {
  id          Int      @id @default(autoincrement())
  userId      Int
  mediaUrl    String
  mediaType   String   @default("image") // "image" | "video"
  text        String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  views       StoryView[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model StoryView {
  id        Int      @id @default(autoincrement())
  storyId   Int
  userId    Int
  viewedAt  DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
}

// ══════════════════════════════════════════
// BOT PLATFORM
// ══════════════════════════════════════════

model Bot {
  id             Int      @id @default(autoincrement())
  token          String   @unique
  username       String   @unique
  name           String
  description    String?
  about          String?
  avatarUrl      String?
  isActive       Boolean  @default(true)
  ownerId        Int
  userId         Int?     @unique // системный User-аккаунт бота (для отображения как обычного пользователя)
  webhookUrl     String?
  webhookSecret  String?
  allowedUpdates String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner           User               @relation("BotOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  user            User?              @relation("BotIdentity", fields: [userId], references: [id], onDelete: SetNull)
  commands        BotCommand[]
  sessions        BotSession[]
  callbackQueries BotCallbackQuery[]

  @@index([ownerId])
  @@index([username])
}

model BotCommand {
  id          Int    @id @default(autoincrement())
  botId       Int
  command     String
  description String
  bot         Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, command])
  @@index([botId])
}

model BotSession {
  id        Int      @id @default(autoincrement())
  botId     Int
  userId    Int
  state     String?
  data      Json?
  updatedAt DateTime @updatedAt
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([botId, userId])
  @@index([botId])
  @@index([userId])
}

model BotCallbackQuery {
  id           Int       @id @default(autoincrement())
  botId        Int
  userId       Int
  messageId    Int
  callbackData String
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())
  bot          Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId])
  @@index([userId])
}

model BotFatherSession {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  step      String   @default("idle")
  data      Json?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSession {
  id           String   @id @default(cuid())
  userId       Int
  deviceName   String
  deviceType   String   @default("desktop")
  os           String?
  browser      String?
  ip           String?
  lastActive   DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
