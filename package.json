{
  "name": "vortex-messanger",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node server.js",
    "dev:next": "next dev",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "lint": "next lint",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.vortex.messenger",
    "productName": "VortexMessenger",
    "copyright": "Copyright © 2026 Vortex",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "public/**/*",
      "!node_modules/.cache",
      "!**/*.ts",
      "!**/*.tsx",
      "!.next",
      "!src"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo (1).ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "public/logo (1).ico",
      "uninstallerIcon": "public/logo (1).ico",
      "installerHeaderIcon": "public/logo (1).ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VortexMessenger"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo (1).ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/logo (1).ico"
    }
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.95.3",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "emoji-mart": "^5.6.0",
    "framer-motion": "^12.34.3",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "linkify-react": "^4.3.2",
    "linkifyjs": "^4.3.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-pwa": "^5.6.0",
    "prisma": "^5.22.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-virtuoso": "^4.18.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "use-sound": "^5.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.6.1",
    "electron-builder": "^24.13.3",
    "electron-is-dev": "^3.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
